PORT=3001
HOST=127.0.0.1

# ── 管理与跨域 ──
# 默认只允许本机访问管理接口和真实音乐生成；局域网/公网访问请设置 ADMIN_TOKEN。
ADMIN_TOKEN=
# 逗号分隔。生产环境跨源访问时显式填写，如 http://localhost:5173,https://example.com
CORS_ORIGINS=

# ── 对象存储（Cloudflare R2） ──
# STORAGE_DRIVER=local (默认，开发) | r2 | s3 | oss
STORAGE_DRIVER=local
# Cloudflare R2 配置（STORAGE_DRIVER=r2 时必填）
S3_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=vibe-audio
S3_ACCESS_KEY=
S3_SECRET_KEY=
# R2 自定义域名（公开访问 URL 前缀）
S3_PUBLIC_URL=https://audio.yourdomain.com

# ── TTAPI (Suno 音乐生成，Suno 无公开 API) ──
# 在 https://ttapi.io 获取密钥
TTAPI_KEY=
# 兼容旧变量名
# SUNO_API_KEY=
TTAPI_BASE_URL=https://api.ttapi.io
TTAPI_SUNO_MV=chirp-v5
USE_FALLBACK_ONLY=false

# ── LLM 供应商选择 ──
# 可选: openai | anthropic | gemini | deepseek | siliconflow | openrouter | custom
#       cli-codex | cli-gemini | cli-claude | cli-kimi
LLM_PROVIDER=openai
LLM_MODEL=

# OpenAI / ChatGPT
OPENAI_API_KEY=

# Anthropic / Claude API
ANTHROPIC_API_KEY=

# Google Gemini API
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# 硅基流动 SiliconFlow
SILICONFLOW_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# 自定义 OpenAI 兼容（LLM_PROVIDER=custom 时使用）
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1

# ── 本地 CLI 调用 ──
# Codex CLI (支持 codex auth / CODEX_API_KEY)
CODEX_CLI_PATH=codex
CODEX_CLI_ARGS=exec,-q
CODEX_CLI_PROMPT_MODE=arg
CODEX_API_KEY=

# Gemini CLI
GEMINI_CLI_PATH=gemini
GEMINI_CLI_ARGS=
GEMINI_CLI_PROMPT_MODE=arg

# Claude Code CLI
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_ARGS=-p,--print
CLAUDE_CLI_PROMPT_MODE=arg

# Kimi CLI
KIMI_CLI_PATH=kimi
KIMI_CLI_ARGS=
KIMI_CLI_PROMPT_MODE=arg
KIMI_API_KEY=

# CLI 超时（毫秒）
LLM_CLI_TIMEOUT_MS=120000
