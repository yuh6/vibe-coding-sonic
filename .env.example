PORT=3001

# ── TTAPI (Suno 音乐生成，Suno 无公开 API) ──
# 在 https://ttapi.io 获取密钥
TTAPI_KEY=
# 兼容旧变量名
# SUNO_API_KEY=
TTAPI_BASE_URL=https://api.ttapi.io
TTAPI_SUNO_MV=chirp-v5
USE_FALLBACK_ONLY=false

# ── LLM 供应商选择 ──
# 可选: openai | anthropic | gemini | deepseek | siliconflow | openrouter | custom
#       cli-codex | cli-gemini | cli-claude | cli-kimi
LLM_PROVIDER=openai
LLM_MODEL=

# OpenAI / ChatGPT
OPENAI_API_KEY=

# Anthropic / Claude API
ANTHROPIC_API_KEY=

# Google Gemini API
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# 硅基流动 SiliconFlow
SILICONFLOW_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# 自定义 OpenAI 兼容（LLM_PROVIDER=custom 时使用）
LLM_API_KEY=
LLM_API_BASE=https://api.openai.com/v1

# ── 本地 CLI 调用 ──
# Codex CLI (支持 codex auth / CODEX_API_KEY)
CODEX_CLI_PATH=codex
CODEX_CLI_ARGS=exec,-q
CODEX_CLI_PROMPT_MODE=arg
CODEX_API_KEY=

# Gemini CLI
GEMINI_CLI_PATH=gemini
GEMINI_CLI_ARGS=
GEMINI_CLI_PROMPT_MODE=arg

# Claude Code CLI
CLAUDE_CLI_PATH=claude
CLAUDE_CLI_ARGS=-p,--print
CLAUDE_CLI_PROMPT_MODE=arg

# Kimi CLI
KIMI_CLI_PATH=kimi
KIMI_CLI_ARGS=
KIMI_CLI_PROMPT_MODE=arg
KIMI_API_KEY=

# CLI 超时（毫秒）
LLM_CLI_TIMEOUT_MS=120000
